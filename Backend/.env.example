PORT=4000
ENVIRONMENT=development

# MongoDB
MONGODB_DEV_URL=mongodb://127.0.0.1:27017/colibri_dev
MONGODB_PROD_URL=mongodb+srv://user:password@cluster.mongodb.net/colibri_prod

# Auth
JWT_SECRET=replace_with_a_long_random_secret

# Google Maps API for backend services
GOOGLE_MAPS_API=replace_with_google_maps_api_key

# Mail (Gmail SMTP)
MAIL_USER=your_account@gmail.com
MAIL_PASS=your_gmail_app_password

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_with_aws_access_key
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret
AWS_BUCKET_NAME=your-s3-bucket-name

# Keep-alive in production
SERVER_URL=http://localhost:4000
RELOAD_INTERVAL=1

# Currency
USD_MXN_RATE=17.50

# Initial admin creation
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=User

